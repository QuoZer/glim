<?xml version="1.0" encoding="UTF-8" ?>
<!-- FastDDS over loopback only (no SHM, no real-NIC fragmentation), large buffers.
     Lets large PointCloud2 cross the host<->docker (--network host) boundary.
     Requires once: sudo sysctl -w net.core.rmem_max=2147483647 net.core.wmem_max=2147483647 -->
<dds xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
  <profiles>
    <transport_descriptors>
      <transport_descriptor>
        <transport_id>udp_lo</transport_id>
        <type>UDPv4</type>
        <sendBufferSize>16777216</sendBufferSize>
        <receiveBufferSize>16777216</receiveBufferSize>
        <interfaceWhiteList>
          <address>127.0.0.1</address>
        </interfaceWhiteList>
      </transport_descriptor>
    </transport_descriptors>
    <participant profile_name="udp_lo_only" is_default_profile="true">
      <rtps>
        <userTransports>
          <transport_id>udp_lo</transport_id>
        </userTransports>
        <useBuiltinTransports>false</useBuiltinTransports>
      </rtps>
    </participant>
  </profiles>
</dds>
