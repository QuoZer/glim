{
  /*** Keyframe-based VGICP odometry estimation ***
  // smoother_lag                : Fixed-lag smoothing window size [sec]
  // use_isam2_dogleg            : Use the dogleg optimizer as the backend of ISAM2 that is slow but more robust
  // isam2_relinearize_skip      :
  // isam2_relinearize_thresh    :
  */
  "odometry_estimation": {
    "so_name": "libodometry_estimation_cpu.so",
    // Initialization params (valid modes: LOOSE, NAIVE -- no TIGHT in this build).
    // LOOSE estimates initial gravity + gyro/accel bias over the window, so it
    // MUST see a still stretch as its FIRST frames -> start bag playback at the
    // early 23-28s stop (5s still): `run_glim_incontainer.sh 0 1.0 24`, which maps
    // ~13 min (almost the whole traverse) with a clean init. Gyro bias floor when
    // still ~0.7 deg/s -> that is what LOOSE locks in here. (Other stops if needed:
    // 228s ~3.8min, or a 12s one at 722s for just the tail.)
    "initialization_mode": "LOOSE",
    "initialization_window_size": 3.0,
    "init_pose_damping_scale": 1e10,
    // Optimizer params
    "smoother_lag": 10.0,
    "use_isam2_dogleg": false,
    "isam2_relinearize_skip": 1,
    "isam2_relinearize_thresh": 0.1,
    "fix_imu_bias": false,
    // Registration settings
    "registration_type": "GICP",
    "max_iterations": 16,
    "lru_thresh": 100,
    "target_downsampling_rate": 0.1,
    // GICP + iVox params
    "ivox_resolution": 0.5,
    "ivox_min_dist": 0.1,
    // VGICP params
    "vgicp_resolution": 0.5,
    "vgicp_voxelmap_levels": 1,
    "vgicp_voxelmap_scaling_factor": 2.0,
    // Optimizer params
    "validate_imu": true,
    "save_imu_rate_trajectory": true,
    "num_threads": 2
  }
}